# RabbitMQ
RABBITMQ_USER=taskscope
RABBITMQ_PASS=taskscope
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672

# Grafana
GRAFANA_USER=admin
GRAFANA_PASS=admin

# OTel (Spring Boot 앱에서 사용)
OTEL_SERVICE_NAME=taskscope-dispatcher
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:14320
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# GitHub (public repo read 권한 PAT — 비인증 시 60 req/h 제한)
GITHUB_TOKEN=ghp_your_token_here

# Anthropic Claude API (Phase 2: stub → 실제 LLM 호출)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# LLM 출력 토큰 한도 (기본 4096, 코드 수정 없이 조정 가능)
LLM_MAX_TOKENS=4096

# task 단위 설정
TASK_UNIT=single_commit

# 가드레일 임계값 (task type별 평균 비용이 이 값 초과 시 premium→standard 강등)
GUARDRAIL_COST_THRESHOLD_USD=0.05

# Prometheus (가드레일 비용 조회용)
PROMETHEUS_URL=http://localhost:19090
